#!/usr/bin/perl
# This is like pacman(1), but prepends "sudo" or "run0" when necessary.
use strict;
use warnings;
use v5.20;

# can only decide whether to add sudo if @ARGV has options in front
my $options = $ARGV[0] // '';
exec 'pacman', @ARGV unless $options =~ /^-/;

# decide whether to sudo or not
my $as_root = 0;
if ($options =~ /D/) {
   $as_root = $options !~ /k/;
}
elsif ($options =~ /S/) {
   $as_root = $options =~ /y/ || $options !~ /[gilps]/;
}
elsif ($options =~ /[RU]/) {
   $as_root = $options !~ /p/;
}
elsif ($options =~ /F/) {
   $as_root = $options =~ /y/;
}

if ($as_root) {
   my @root_tool = (`which sudo 2>/dev/null` eq '') ? ('run0', '--background=') : ('sudo');
   exec @root_tool, 'pacman', @ARGV;
}
else {
   exec 'pacman', @ARGV;
}
